tap "adoptopenjdk/openjdk"
tap "drone/drone"
tap "homebrew/bundle"
tap "homebrew/cask"
tap "homebrew/core"
tap "homebrew/services"
tap "mshell/mshell", "git@github.skyscannertools.net:mshell/homebrew-mshell.git"

# Clone of cat(1) with syntax highlighting and Git integration
brew "bat"
# GNU File, Shell, and Text utilities
brew "coreutils"
# GitHub command-line tool
brew "gh"
# GNU Pretty Good Privacy (PGP) package
brew "gnupg", link: false
# Open-source build automation tool based on the Groovy and Kotlin DSL
brew "gradle"
# Command-line interface for JFrog products
brew "jfrog-cli"
# Powerful, clean, object-oriented scripting language
brew "ruby"
# Watch files and take action when they change
brew "watchman"
# Fish-like fast/unobtrusive autosuggestions for zsh
brew "zsh-autosuggestions"
# Fish shell like syntax highlighting for zsh
brew "zsh-syntax-highlighting"
# Skyscanner Artifactory login command.
brew "mshell/mshell/artifactory-cli-login"
# MShell helper scripts
brew "mshell/mshell/mshell-tools"
# AdoptOpenJDK OpenJDK (Java) Development Kit
cask "adoptopenjdk8"
# Text editor
cask "atom"
